# TokenOps environment configuration.
# Copy to `.env` and fill in real values. Never commit `.env`.
# All variables are loaded through proxy/config.py — do not read os.environ elsewhere.

# --- OpenRouter ---
# API key for OpenRouter. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Database ---
# asyncpg native URL — note: no `+asyncpg` driver suffix (that's SQLAlchemy-only).
DATABASE_URL=postgresql://tokenops:tokenops@localhost:5432/tokenops

# --- Qdrant Cloud (semantic cache) ---
# Full URL including https:// and :6333 port. Get from cloud.qdrant.io.
QDRANT_URL=https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333
# Leave blank for local Qdrant (Docker, no auth).
QDRANT_API_KEY=your-qdrant-api-key-here

# --- Langfuse (LLM observability) ---
# Get keys at langfuse.com -> Settings -> API Keys.
# All three optional — if unset, instrumentation is a no-op.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- Modal (embedder) ---
# Name of the deployed Modal app that exposes the `embed` function.
MODAL_EMBEDDER_APP=tokenops-embedder

# --- Host application ---
# Where the host_app demo sends its traffic. Should point at the proxy.
PROXY_URL=http://localhost:8000

# --- Optimizer agent ---
# How often APScheduler triggers the LangGraph optimizer run.
AGENT_RUN_INTERVAL_MINUTES=15

# Protect /v1/agent/* in production. Accept via Bearer token or X-TokenOps-Admin-Key.
# Leave unset for local dev (endpoints are open).
AGENT_ADMIN_KEY=your-admin-key-here

# How often the proxy polls Postgres for a newer routing_rules row.
RULES_RELOAD_INTERVAL_SEC=60

# --- Tenant API keys (v2 multi-tenant) ---
# Tenants are NOT seeded in db/schema.sql — create them with:
#   python scripts/create_tenant.py --id genie-platform --name "Genie Platform" --budget 1000
# The script prints the plaintext key once; store it in your secret manager.
# Clients pass it as: `Authorization: Bearer tok_...`
