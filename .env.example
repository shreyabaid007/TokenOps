# TokenOps environment configuration.
# Copy to `.env` and fill in real values. Never commit `.env`.
# All variables are loaded through proxy/config.py — do not read os.environ elsewhere.

# --- OpenRouter ---
# API key for OpenRouter. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Database ---
# asyncpg native URL — note: no `+asyncpg` driver suffix (that's SQLAlchemy-only).
DATABASE_URL=postgresql://tokenops:tokenops@localhost:5432/tokenops

# --- Qdrant (semantic cache) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Modal (embedder) ---
# Name of the deployed Modal app that exposes the `embed` function.
MODAL_EMBEDDER_APP=tokenops-embedder

# --- Host application ---
# Where the host_app demo sends its traffic. Should point at the proxy.
PROXY_URL=http://localhost:8000

# --- Optimizer agent ---
# How often APScheduler triggers the LangGraph optimizer run.
AGENT_RUN_INTERVAL_MINUTES=15

# How often the proxy polls Postgres for a newer routing_rules row.
RULES_RELOAD_INTERVAL_SEC=60
