# TokenOps optimizer agent — same base as the proxy, different entrypoint.
#
# Build:  docker build -f Dockerfile.agent -t tokenops-agent .
# Run:    docker run --env-file .env tokenops-agent

FROM python:3.11-slim AS builder

WORKDIR /build

RUN apt-get update \
    && apt-get install -y --no-install-recommends gcc g++ \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt \
    && pip install --no-cache-dir --prefix=/install \
       "https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.7.1/en_core_web_sm-3.7.1-py3-none-any.whl"

FROM python:3.11-slim AS runtime

RUN groupadd --system tokenops \
    && useradd --system --gid tokenops --no-create-home tokenops

WORKDIR /app

COPY --from=builder /install /usr/local
COPY proxy/ proxy/
COPY agent/ agent/

USER tokenops

CMD ["python", "agent/scheduler.py"]
